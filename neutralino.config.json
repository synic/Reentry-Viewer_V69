{
  "applicationId": "com.reentryviewer.v69",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "nativeAllowList": [
    "app.*",
    "window.*",
    "debug.log"
  ],
  "modes": {
    "window": {
      "title": "Reentry Viewer V69",
      "width": 1400,
      "height": 900,
      "minWidth": 1024,
      "minHeight": 768,
      "center": true,
      "resizable": true,
      "icon": "/resources/icons/appIcon.png"
    }
  },
  "cli": {
    "binaryName": "reentry-viewer",
    "resourcesPath": "/resources/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  }
}